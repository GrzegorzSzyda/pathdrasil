{
    "name": "pathdrasil",
    "version": "0.2.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --hot --port=0 src/index.tsx",
        "start": "NODE_ENV=production bun src/index.tsx",
        "build": "bun run build.ts",
        "prepare": "husky",
        "fix:staged": "lint-staged",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
        "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
        "fix": "bun run lint:fix && bun run format:fix"
    },
    "dependencies": {
        "bun-plugin-tailwind": "^0.1.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.2"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/bun": "^1.3.11",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "oxlint": "^1.57.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": "oxlint --fix",
        "*.{js,jsx,ts,tsx,css,md,json}": "prettier --write"
    }
}
